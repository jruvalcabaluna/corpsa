<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="product_template_tree_view_salos" model="ir.ui.view">
        <field name="name">product.template.product.tree.salos</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">

           <!-- <xpath expr="//tree" position="attributes">
                <attribute name="decoration-danger">state == 'Desviación'</attribute>
            </xpath>-->

            <xpath expr="//field[@name='list_price']" position="after">

               <!-- <field name="last_purchase_price" string="Último costo"/>-->

                <!--<field name="min_price"/>-->

                <field name="replenishment_margin" widget="percentage"/>
                <field name="real_margin" widget="percentage"/>
                <field name="repo_margin" widget="percentage"/>
                <field name="min_margin_product" widget="percentage"/>
                <field name="min_margin_result" widget="percentage" string="% Desv"/>
                <field name="cost_repo" string="Costo Reposición"/>



            </xpath>
        </field>
    </record>
</odoo>
