<odoo>

    <record id="stock_card_report_wizard_form" model="ir.ui.view">
        <field name="name">stock.card.report.wizard.form</field>
        <field name="model">stock.card.report.wizard</field>
        <field name="arch" type="xml">
            <form>
                <group name="criteria">
                    <group>
                        <field name="is_interval"/>
                        <field name="interval_type"/>
                        <field name="date_range_id" string="Periodo"/>
                        <field name="date_from" string="Fecha Inicial"/>
                        <field name="date_to" string="Fecha Final"/>
                    </group>
                    <group>
                        <field name="location_id" string="Almacen" options="{'no_create': True, 'no_create_edit':True}"/>
                        <field name="product_ids" string="Productos" widget="many2many_tags"
                               attrs="{'invisible': [('is_interval', '=', False)]}"/>
                        <field name="product_ids" string="Productos" widget="many2many_tags"
                               options="{'no_create': True, 'no_create_edit':True}"
                               attrs="{'invisible': [('is_interval', '=', True)]}"
                               readonly="0"/>
                    </group>
                </group>
                <footer>
                    <button name="button_export_html" string="Ver" type="object" default_focus="1" class="oe_highlight"/>
                    <button name="button_export_pdf" string="Exportar PDF" type="object"/>
                    <button name="button_export_pdf_global" string="Exportar PDF Global" type="object" class="oe_highlight"/>
                    <button name="button_export_xlsx" string="Exportar XLSX" type="object"/>
                    <button string="Cancelar" class="oe_link" special="cancel" />
                </footer>
            </form>
        </field>
    </record>

    <record id="stock_card_report_action" model="ir.actions.act_window">
        <field name="name">Kardex Inventario</field>
        <field name="res_model">stock.card.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="stock_card_report_menu" action="stock_card_report_action" parent="stock.menu_warehouse_report" sequence="30"/>

</odoo>
