    <t t-name="ButtonSetBundlePack" owl="1">
        <div class="control-button"  t-att-class="{ highlight: isHighlighted }">
            <i class="fa fa-list"></i>
            <span>Bundle Pack</span>
            <span></span>
        </div>
    </t>

     <t t-name="ProductScreen" t-inherit="point_of_sale.ProductScreen" t-inherit-mode="extension" owl="1">
        <xpath expr="//div[hasclass('subpads')]" position="before">
            <!-- <div style="width:94%;"> -->
