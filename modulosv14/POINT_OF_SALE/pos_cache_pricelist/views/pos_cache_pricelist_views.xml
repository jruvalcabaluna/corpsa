<?xml version="1.0"?>
<odoo>
    <data>
        <record id="pos_config_view_form_inherit_pos_cache_pricelist" model="ir.ui.view">
            <field name="name">pos.config.form.inherit.pos.cache.pricelist</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.pos_config_view_form" />
            <field name="arch" type="xml">
                <xpath expr="//field[@name='currency_id']" position="after">
                    <field name='oldest_cache_pricelist_time'/>
                    <button name='delete_cache_pricelist' type="object"
                        string="Invalidate PriceList cache"
                        attrs="{'invisible': [('oldest_cache_pricelist_time', '=', False)]}"/>

                    <field name='oldest_cache_pricelist_item_time'/>
                    <button name='delete_cache_pricelist_item' type="object"
                        string="Invalidate PriceList Item cache"
                        attrs="{'invisible': [('oldest_cache_pricelist_item_time', '=', False)]}"/>

                </xpath>
            </field>
        </record>
    </data>
</odoo>