<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <t t-name="ProductItemHide" t-inherit="point_of_sale.ProductItem" t-inherit-mode="extension" owl="1">
        <xpath expr="//article" position="attributes">
            <attribute name="t-att-style">props.product.pos_hide_product ? 'display: none' : ''</attribute>
        </xpath>
    </t>
</templates>