<?xml version="1.0" encoding="UTF-8" ?>
<templates id="template" xml:space="preserve">
    <t t-name="CategorySimpleButtonHide" t-inherit="point_of_sale.CategorySimpleButton" t-inherit-mode="extension" owl="1">
        <xpath expr="//span" position="attributes">
            <attribute name="t-att-style">props.category.name == 'COMPLEMENTOS' ? 'display: none' : ''</attribute>
        </xpath>
    </t>

    <t t-name="CategoryButton" t-inherit="point_of_sale.CategoryButton" t-inherit-mode="extension" owl="1">
        <xpath expr="//span" position="attributes">
            <attribute name="t-att-style">props.category.name == 'COMPLEMENTOS' ? 'display: none' : ''</attribute>
        </xpath>
    </t>

</templates>
