<?xml version="1.0" encoding="utf-8"?>
    <odoo>
        <record id="pos_config_view_form_inherit_pos_8a_warranty" model="ir.ui.view">
            <field name="name">pos.config.form.inherit.pos.8a.warranty</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="point_of_sale.pos_config_view_form" />
            <field name="arch" type="xml">
				<xpath expr="//div[3]" position="after">

                    <div class="row mt16 o_settings_container" id="session_config">
						<div class="col-xs-12 col-md-6 o_setting_box">
							<div class="o_setting_right_pane">
								<label for="charges_category_id"/>
								<div class="text-muted">
									Select Category Charges
								</div>
								<div class="content-group mt16">
									<field name="charges_category_id"/>
								</div>
							</div>
						</div>
					</div>

                </xpath>
            </field>
        </record>
    </odoo>