<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="purchase_order_charge_form_view" model="ir.ui.view">
            <field name="name">purchase.order.charge.form.view</field>
            <field name="model">purchase.order</field>
            <field name="inherit_id" ref="purchase.purchase_order_form"/>
            <field name="arch" type="xml">
                <field name="discount" position="after">
                    <field name="desc2" invisible="1"/>
                </field>
                <xpath expr="//form//sheet//notebook//page//field[@name='order_line']//form//field[@name='taxes_id']" position="after">
                    <field name="desc2" invisible="1"/>
                </xpath>
                <xpath expr="//form//sheet//notebook//page//field[@name='order_line']//tree//field[@name='taxes_id']" position="after">
                    <field name="desc2" invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>