<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="sale_order_charge_form_view" model="ir.ui.view">
            <field name="name">sale.order.charge.form.view</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form//header//button[@name='action_draft']" position="after">
                    <button name="add_charges" string="Agregar cargos" type="object" class="oe_highlight" invisible="1"/>
                </xpath>
                <field name="discount" position="after">
                    <field name="desc2" invisible="1"/>
                </field>
                <xpath expr="//form//sheet//notebook//page//field[@name='order_line']//form//field[@name='tax_id']" position="after">
                    <field name="desc2" invisible="1"/>
                </xpath>
                <xpath expr="//form//sheet//notebook//page//field[@name='order_line']//tree//field[@name='tax_id']" position="after">
                    <field name="desc2" invisible="1"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>