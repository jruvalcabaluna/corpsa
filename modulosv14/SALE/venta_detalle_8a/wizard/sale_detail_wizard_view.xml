<?xml version="1.0"?>
<odoo>
    <data>
        
        <record model="ir.ui.view" id="sale_detail_wizard_form_view">
            <field name="name">sale.detail.wizard.form.view</field>
            <field name="model">sale.detail.wizard</field>
            <field name="priority" eval="20"/>
            <field name="arch" type="xml">
                <form string="Detalle ventas">
                    <sheet>
                        <group string="General">
                            <group>
                                <field name="start_date" required="1"/>
                            </group>
                            <group>
                                <field name="end_date"/>
                            </group>
                        </group>

                    </sheet>
                    
                    <footer>
                        <button name="action_get_sales" type="object" class="oe_highlight" string="Ver detalle de ventas"/>
                    </footer>
                </form>
            </field>
        </record>

        <record model="ir.ui.view" id="sale_detail_wizard_tree_view">
            <field name="name">sale.detail.wizard.tree.view</field>
            <field name="model">sale.detail.wizard</field>
            <field name="priority" eval="20"/>
            <field name="arch" type="xml">
                <tree>
                    <field name="start_date"/>
                    <field name="end_date"/>
                </tree>
            </field>
        </record>

        <record id="action_sale_detail_wizard" model="ir.actions.act_window">
            <field name="name">Detalle ventas</field>
            <field name="type">ir.actions.act_window</field>
            <field name="res_model">sale.detail.wizard</field>
            <field name="view_mode">form</field>
            <field name="context">{}</field>
            <field name="domain">[]</field>
            <field name="target">new</field>
            <field name="help" type="html">
              <p class="o_view_nocontent_smiling_face">
                Venta al detalle
              </p>
            </field>
        </record>

        <!--<record id="action_sale_detail_wizard_tree" model="ir.actions.act_window.view">
            <field name="sequence" eval="1"/>
            <field name="view_mode">tree</field>
            <field name="view_id" ref="sale_detail_wizard_tree_view"/>
            <field name="act_window_id" ref="action_sale_detail_wizard"/>
        </record>-->

        <record id="action_sale_detail_wizard_form" model="ir.actions.act_window.view">
            <field name="sequence" eval="2"/>
            <field name="view_mode">form</field>
            <field name="view_id" ref="sale_detail_wizard_form_view"/>
            <field name="act_window_id" ref="action_sale_detail_wizard"/>
        </record>

        <menuitem id="menu_action_sale_detail_wizard" action="action_sale_detail_wizard" sequence="3" parent="sale.menu_sale_report"/>

    </data>
</odoo>