<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_product_week_days_tree" model="ir.ui.view">
        <field name="name">week.days.tree</field>
        <field name="model">week.days</field>
        <field name="type">tree</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
        <tree string="Week days">
            <field name="name"/>
        </tree>
        </field>
    </record>

    <record id="view_product_week_days_form" model="ir.ui.view">
        <field name="name">week.days.form</field>
        <field name="model">week.days</field>
        <field name="type">form</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
        <form string="Week days">
            <sheet>
                <group name="main">
                    <group name="name">
                        <field name="name" select="1"/>
                    </group>
                </group>
            </sheet>
        </form>
        </field>
    </record>

    <record id="view_product_week_days_search" model="ir.ui.view">
        <field name="name">week.days.search</field>
        <field name="model">week.days</field>
        <field name="type">search</field>
        <field name="priority" eval="8"/>
        <field name="arch" type="xml">
            <search string="Week days">
                <field name="name" select="True"/>
            </search>
        </field>
    </record>

    <record model="ir.actions.act_window" id="act_open_product_week_days_view">
        <field name="name">Week days</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">week.days</field>
        <field name="view_type">form</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_product_week_days_search"/>
        <field name="domain">[]</field>
        <field name="context">{}</field>
    </record>

    <record model="ir.actions.act_window.view" id="act_open_product_week_days_view_form">
        <field name="act_window_id" ref="act_open_product_week_days_view"/>
        <field name="sequence" eval="20"/>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_product_week_days_form"/>
    </record>

    <record model="ir.actions.act_window.view" id="act_open_product_week_days_view_tree">
        <field name="act_window_id" ref="act_open_product_week_days_view"/>
        <field name="sequence" eval="10"/>
        <field name="view_mode">tree</field>
        <field name="view_id" ref="view_product_week_days_tree"/>
    </record>

    <menuitem id="menu_product_week_days_config"
        parent="sale.product_menu_catalog"
        groups="sales_team.group_sale_manager"
        sequence="22"
        action="act_open_product_week_days_view"/>
</odoo>
