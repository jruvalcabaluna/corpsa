<odoo>
    <data>

        <record id="odoopi_dashboard_sale_search_id" model="ir.ui.view">
            <field name="model">dashboard.sale</field>
            <field name="arch" type="xml">
                <search>
                    <group expand="0" string="Group By">
                        <filter string="Sale Representative" name="representative" domain="[]" context="{'group_by': 'user_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <record id="odoopi_dashboard_sale_graph_id" model="ir.ui.view">
            <field name="model">dashboard.sale</field>
            <field name="arch" type="xml">
                <graph>
                    <field name="user_id" string="Sale Representative"/>
                    <field name="partner_sale_no" type="measure"/>

                </graph>
            </field>
        </record>

