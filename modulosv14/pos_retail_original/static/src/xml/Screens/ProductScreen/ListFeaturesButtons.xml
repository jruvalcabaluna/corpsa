<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="ListFeaturesButtons" owl="1">
        <div class="button-extend" t-att-class="{oe_hidden: env.session.restaurant_order}">
            <span t-on-click="setOrderToInvoice"
                    title="orderToInvoiceString"
                    t-att-class="{'highlight': orderWillProcessingToInvoice}"
                    class="control-button">
                <i class="fa fa-file-text-o"/>
                <span t-if="env.isShowKeyBoard">
                    <i class="fa fa-keyboard-o"/> F2
                </span>
                <span class="button-label"><t t-esc="orderToInvoiceString"/></span>
            </span>
            <span t-on-click="selectLoyaltyReward"
                    t-if="env.pos.rewards"
                    title="Loyalty Program"
                    class="control-button">
                <i class="fa fa-gift"/>
                <span class="button-label">
                    Loyalty Rewards
                </span>
            </span>
            <span t-if="env.pos.config.allow_remove_line and !env.session.restaurant_order"
                    t-on-click="clearCartItems"
                    title="Clear Items in Cart"
                    class="control-button">
                <i class="fa fa-trash"/>
                <span t-if="env.isShowKeyBoard">
                    <i class="fa fa-keyboard-o"/> F3
                </span>
                <span class="button-label">Clear Items</span>
            </span>
            <span t-if="(env.pos.config.report_product_summary || env.pos.config.report_order_summary || env.pos.config.report_payment_summary || env.pos.config.report_sale_summary)"
                    t-on-click="showReports"
                    title="Reports"
                    class="control-button">
                <i class="fa fa-line-chart"/>
                <span class="button-label">Reports</span>
            </span>
            <span t-if="env.pos.config.return_products and !env.session.restaurant_order"
                    t-on-click="changeToReturnMode"
                    title="Change to Return Order"
                    class="control-button"
                    t-att-class="{'highlight': isReturnOrder}">
                <i class="fa fa-arrow-left"/>
                <span t-if="env.isShowKeyBoard">
                    <i class="fa fa-keyboard-o"/> F4
                </span>
                <span class="button-label"><t t-esc="returnStringButton"/></span>
            </span>
            <span t-if="env.pos.config.review_receipt_before_paid and !env.session.restaurant_order"
                    t-on-click="printReceipt"
                    title="Print Receipt"
                    class="control-button">
                <i class="fa fa-print"/>
                <span t-if="env.isShowKeyBoard">
                    <i class="fa fa-keyboard-o"/> F6
                </span>
                <span class="button-label">Receipt</span>
            </span>
            <span t-if="env.pos.config.whatsapp_api and env.pos.config.whatsapp_token"
                    t-on-click="sendReceiptViaWhatsApp"
                    title="Send Receipt via WhatsApp"
                    class="control-button">
                <i class="fa fa-whatsapp" aria-hidden="true"></i>
                <span class="button-label"> WhatsApp</span>
            </span>
            <span t-if="env.pos.couponPrograms"
                    t-on-click="addCoupon"
                    title="Add Coupon Code"
                    class="control-button">
                <i class="fa fa-gift"/>
                <span class="button-label">Coupon Code</span>
            </span>
            <span t-if="env.pos.config.discount and env.pos.config.discount_ids.length != 0"
                    t-on-click="setGlobalDiscount"
                    title="Set Global Discount"
                    class="control-button">
                <i class="fa fa-sort-amount-desc"/>
                <span class="button-label">Global Disc</span>
            </span>
            <span t-if="env.pos.config.discount_value"
                    t-on-click="setDiscountValue"
                    title="Set Discount Values"
                    class="control-button">
                <i class="fa fa-sort-amount-desc"/>
                <span class="button-label">Disc Value</span>
            </span>
            <span t-if="env.pos.config.note_order"
                    t-on-click="setNotes"
                    title="Set Notes Order"
                    class="control-button">
                <i class="fa fa-edit"/>
                <span t-if="env.isShowKeyBoard">
                    <i class="fa fa-keyboard-o"/> F7
                </span>
                <span class="button-label">Notes</span>
            </span>
            <span t-if="env.pos.services_charge"
                    t-on-click="setServicesOrder"
                    title="Set Services"
                    class="control-button">
                <i class="fa fa-level-down"/>
                <span t-if="env.isShowKeyBoard">
                    <i class="fa fa-keyboard-o"/> F8
                </span>
                <span class="button-label">Services</span>
            </span>
            <span t-if="env.pos.config.signature_order"
                    t-on-click="signatureOrder"
                    title="Signature to Order"
                    class="control-button">
                <i class="fa fa-check-square-o"/>
                <span class="button-label">Signature</span>
            </span>
            <span t-if="env.pos.tables and env.pos.config.allow_lock_table"
                    t-on-click="lockTable"
                    title="Lock Table"
                    class="control-button">
                <i class="fa fa-lock"/>
                <span class="button-label">Lock Table</span>
            </span>
            <span t-if="env.pos.config.quickly_payment_full"
                    t-on-click="quicklyPaidOrder"
                    title="Quickly Paid Order"
                    class="control-button secondary-button">
                <i class="fa fa-bolt"/>
                <span class="button-label">Quickly Payment</span>
            </span>
            <span t-if="env.pos.config.paid_partial"
                    t-on-click="partialPaidOrder"
                    title="Partial Paid Order"
                    class="control-button secondary-button">
                <i class="fa fa-chevron-right"/>
                <span class="button-label">Partial Payment</span>
            </span>
            <span t-if="env.pos.tables and env.pos.config.allow_split_table"
                    t-on-click="transferItemsToAnotherTable"
                    title="Transfer Items to another Table"
                    class="control-button">
                <i class="fa fa-arrow-right"/>
                <span class="button-label">Transfer Items</span>
            </span>
            <t t-foreach="props.controlButtons" t-as="cb" t-key="cb.name">
                <t t-component="cb.component" t-key="cb.name" />
            </t>
        </div>
    </t>

</templates>
