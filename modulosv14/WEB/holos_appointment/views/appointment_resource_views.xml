<?xml version="1.0"?>
<odoo>

    <record id="view_appointment_resource_tree" model="ir.ui.view">
        <field name="name">appointment.resource.tree</field>
        <field name="model">appointment.resource</field>
        <field name="arch" type="xml">
            <tree string="Appointment Resource" editable="bottom">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="action_appointment_resource" model="ir.actions.act_window">
        <field name="name">Appointment Resource</field>
        <field name="res_model">appointment.resource</field>
        <field name="view_id" ref="view_appointment_resource_tree"/>
    </record>

</odoo>
