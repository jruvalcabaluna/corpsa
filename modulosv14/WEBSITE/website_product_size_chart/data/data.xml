	  <record id="website_size_chart_sweatshirt" model="website.size.chart">            
            <field name="name">Size Conversion Chart For Full Sleeve Sweatshirt</field>           
         	<field name="row" >7</field>   
         	<field name="col" >6</field>     
         	<field name="chart_info"  type="html">
				<table class="table">
				<thead>
					<tr><th>Sizes</th><th>Chest</th><th>Neck</th>
					<th>Shoulder</th><th>Sleeve</th><th>Length</th></tr>
				</thead>
				<tbody>
					<tr><td>XS</td><td>36</td><td>7.25</td><td>17</td><td>24</td><td>23</td></tr>
					<tr><td>S</td><td>38</td><td>7.5</td><td>17.75</td><td>24.5</td><td>25</td></tr>
					<tr><td>M</td><td>40</td><td>7.75</td><td>18.5</td><td>25</td><td>26</td></tr>
					<tr><td>L</td><td>42</td><td>8</td><td>19.25</td><td>25.5</td><td>28</td></tr>
					<tr><td>XL</td><td>44</td><td>8.25</td><td>20</td><td>26</td><td>29</td></tr>
					<tr><td>XXL</td><td>46</td><td>8.5</td><td>20.75</td><td>26.5</td><td>30</td></tr>
				</tbody>
				</table>
			</field>
 	    	<field name="measure_info"  type="html">
				<p><b>Sleeve  </b>Measure from the shoulder seam through the outer arm to the cuff / hem.</p>
				<p><b>Neck Width  </b>Measured horizontally across the neck.</p>
				<p><b>Shoulder  </b>Measure the shoulder at the back, from edge to edge with arms relaxed on both sides.</p>
				<p><b>Length  </b>Measure from the highest point of the shoulder seam to the bottom hem of the garment's.</p>
				<p><b>Chest  </b>Measure around the body under the arms at the fullest part of the chest with your arms relaxed at both sides.</p>
			</field>         	
         	<field name="link_text" >Size Conversion</field>         	
         	<field name="image" type="base64" file="website_product_size_chart/static/src/img/sweatshirt.jpg"></field>
         	<field name="product_tmpl_ids" eval="[(6,0,[ref('wk_sweatshirt_product_template')])]"/>             
        </record>
