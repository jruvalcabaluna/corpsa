        <record id="wk_size_chart_category" model="product.category">
            <field name="name">Test  SIZE Chart</field>
        </record>

         <record id="wk_product_uom_categ__size_chart" model="uom.uom">
            <field name="category_id" ref="uom.product_uom_categ_unit"/>
            <field name="name">Test  SIZE Chart</field>
            <field eval="1.0" name="factor"/>
            <field eval="4.0" name="rounding"/>
			 <field name="uom_type">smaller</field>
        </record>

    	<record id="wk_jeans" model="product.product">
