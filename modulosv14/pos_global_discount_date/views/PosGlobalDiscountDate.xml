<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <data>

        <record id="pos_global_discount_date_form" model="ir.ui.view">
            <field name="name">pos.global.discount.date.form</field>
            <field name="model">pos.global.discount.date</field>
            <field name="arch" type="xml">
                <form string="Global Discount Date">
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="type"/>
<!--                                <field name="branch_ids" widget="many2many_tags"/>-->
                            </group>
                            <group>
                                <field name="amount"/>
                                <field name="reason"/>
                                <field name="product_id"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="pos_global_discount_date_tree" model="ir.ui.view">
            <field name="name">pos.global.discount.date.tree</field>
            <field name="model">pos.global.discount.date</field>
            <field name="arch" type="xml">
                <tree string="Global Discounts Date">
                    <field name="name"/>
                    <field name="type"/>
                    <field name="amount"/>
<!--                    <field name="branch_ids" widget="many2many_tags"/>-->
                </tree>
            </field>
        </record>

        <record id="pos_global_discount_date_search" model="ir.ui.view">
            <field name="name">pos.global.discount.date.search</field>
            <field name="model">pos.global.discount.date</field>
            <field name="arch" type="xml">
                <search string="Global Discounts Date">
                    <field name="name"/>
                    <field name="amount"/>
                    <field name="product_id"/>
                </search>
            </field>
        </record>

        <record model="ir.actions.act_window" id="action_global_pos_discount_date">
            <field name="name">Global Discounts Date</field>
            <field name="res_model">pos.global.discount.date</field>
            <field name="view_mode">tree,form</field>
        </record>

        <menuitem id="menu_action_global_pos_discount_date"
                  name="Discount Global Date"
                  action="action_global_pos_discount_date"
                  parent="pos_retail.menu_master_data"
                  sequence="7"/>

    </data>
</odoo>