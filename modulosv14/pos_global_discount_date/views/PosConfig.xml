<odoo>
    <data>

        <record model="ir.ui.view" id="pos_config_discount_date">
            <field name="name">pos.config.discount.date</field>
            <field name="model">pos.config</field>
            <field name="inherit_id" ref="pos_retail.pos_config_retail"/>
            <field name="arch" type="xml">
                <xpath expr="//notebook//page//group//group//field[@name='discount']" position="after">
                    <field name="discount_date"/>
                    <field name="discount_date_ids" widget="many2many_tags"
                                           attrs="{'invisible': [('discount', '=', False)], 'required' : [('discount', '=', True)]}"/>
                </xpath>
            </field>
        </record>

    </data>
</odoo>