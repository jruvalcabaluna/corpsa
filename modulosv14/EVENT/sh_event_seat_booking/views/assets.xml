<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="assets_frontend" name="Seat assets frontend" inherit_id="website.assets_frontend">
        <xpath expr="." position="inside">
            <script type="text/javascript" src="/sh_event_seat_booking/static/src/js/jquery.seat-charts.js"></script>
            <link rel="stylesheet" type="text/css" href="/sh_event_seat_booking/static/src/css/jquery.seat-charts.css" />
            <script type="text/javascript" src="/sh_event_seat_booking/static/src/js/seat_booking.js"></script>
        </xpath>
    </template>

    <template id="assets_backend" name="Event Board Assets" inherit_id="web.assets_backend" priority="20">
        <xpath expr="." position="inside">
            <script type="text/javascript" src="/sh_event_seat_booking/static/src/js/eventboard.js"></script>
            <script type="text/javascript" src="/sh_event_seat_booking/static/src/js/jquery.seat-charts.js"></script>
            <link rel="stylesheet" type="text/css" href="/sh_event_seat_booking/static/src/css/jquery.seat-charts.css" />
        </xpath>
    </template>
</odoo>
