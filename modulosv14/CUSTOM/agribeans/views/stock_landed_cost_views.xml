<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_mrp_landed_costs_form_agribeans" model="ir.ui.view">
        <field name="name">mrp.landed.cost.form.agribeans</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="mrp_landed_costs.view_mrp_landed_costs_form" />
        <field name="arch" type="xml">
            <xpath expr="//field[@name='mrp_production_ids']" position="attributes">
                <attribute name="context">{'show_lots': 1}</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_stock_landed_cost_form_template" model="ir.ui.view">
        <field name="name">stock.landed.cost.form.agribeans</field>
        <field name="model">stock.landed.cost</field>
        <field name="inherit_id" ref="stock_landed_costs.view_stock_landed_cost_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vendor_bill_id']" position="after">
                <field name="stock_landed_cost_template_id"/>
            </xpath>
        </field>
    </record>

</odoo>