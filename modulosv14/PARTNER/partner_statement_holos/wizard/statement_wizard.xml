<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <!-- wizard action on res.partner -->
    <record id="activity_statement_holos_wizard_action" model="ir.actions.act_window">
        <field name="name">Estado de la cuenta del cliente</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="res_model">activity.statement.holos.wizard</field>
        <field name="view_mode">form</field>
        <field name="groups_id" eval="[(4, ref('partner_statement_holos.group_activity_statement_holos'))]"/>
        <field name="target">new</field>
    </record>
    <record id="outstanding_statement_holos_wizard_action" model="ir.actions.act_window">
        <field name="name">Estado de los pendientes de la cuenta del cliente</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="res_model">outstanding.statement.holos.wizard</field>
        <field name="view_mode">form</field>
        <field name="groups_id" eval="[(4, ref('partner_statement_holos.group_outstanding_statement_holos'))]"/>
        <field name="target">new</field>
    </record>
    <!-- wizard view -->
    <record id="statement_common_holos_view" model="ir.ui.view">
        <field name="name">Statement Common Holos Wizard View</field>
        <field name="model">statement.common.holos.wizard</field>
        <field name="arch" type="xml">
            <form name="Report Options">
                <div style="text-align:justify" name="info">
                    <span class="o_form_label">
                        Los detalles de antigüedad se pueden mostrar en el informe, expresados en bloques de antigüedad,
                        para que el contacto pueda revisar cuánto está abierto, vencido o atrasado.
                    </span>
                </div>
                <hr />
                <group>
                    <group name="main_info">
                        <field name="company_id" options="{'no_create': True}" groups="base.group_multi_company"/>
                        <label for="account_type" />
                        <field name="account_type" nolabel="1" widget="radio" />
                    </group>
                    <group name="aging_report">
                        <field name="show_aging_buckets" />
                        <field name="aging_type" />
                    </group>
                </group>
                <group>
                    <group name="dates">
                        <field name="date_end" />
                    </group>
                    <group name="multiple_partners">
                        <field name="number_partner_ids" readonly="1" invisible="1" />
                        <field name="filter_partners_non_due" attrs="{'invisible': [('number_partner_ids', '=', 1)]}"/>
                        <field name="filter_negative_balances" attrs="{'invisible': [('number_partner_ids', '=', 1)]}"/>
                    </group>
                </group>
                <footer>
                    <button name="button_export_html" string="Ver" type="object" default_focus="1" class="oe_highlight"/>
                    o
                    <button name="button_export_pdf" string="Exportar PDF" type="object"/>
                    o
                    <button name="button_export_xlsx" string="Exportar XLSX" type="object"/>
                    o
                    <button string="Cancelar" class="oe_link" special="cancel" />
                </footer>
            </form>
        </field>
    </record>
    <record id="outstanding_statement_holos_wizard_view" model="ir.ui.view">
        <field name="name">Outstanding Statement Holos Wizard</field>
        <field name="model">outstanding.statement.holos.wizard</field>
        <field name="inherit_id" ref="partner_statement_holos.statement_common_holos_view"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='info']/span" position="before">
                <span class="o_form_label">
                    El pendiente del estado de cuenta proporciona detalles de todas las cuentas pendientes por cobrar
                    y por pagar hasta una fecha en particular.
                    Esto incluye todas las facturas impagadas, los reembolsos no reclamados y pagos pendientes.
                    La lista es mostrada en orden cronológico y separada por monedas.
                </span>
                <br />
                <br />
            </xpath>
        </field>
    </record>
    <record id="activity_statement_holos_wizard_view" model="ir.ui.view">
        <field name="name">Estado de Cuenta Cliente Holos Wizard</field>
        <field name="model">activity.statement.holos.wizard</field>
        <field name="inherit_id" ref="partner_statement_holos.statement_common_holos_view"/>
        <field name="mode">primary</field>
        <field name="arch" type="xml">
            <xpath expr="//div[@name='info']/span" position="before">
                <span class="o_form_label">
                    El estado de la cuenta proporciona detalles de toda la actividad en las cuentas por cobrar y
                    por pagar del cliente entre dos fechas seleccionadas.
                    Esto incluye todas las facturas, notas de crédito y pagos.
                    Cualquier saldo pendiente con fecha anterior al período seleccionado aparecerá como un saldo
                    arrastrado en la parte superior del estado de la cuenta.
                    La lista es mostrada en orden cronológico y separada por monedas.
                </span>
                <br />
                <br />
            </xpath>
            <xpath expr="//field[@name='date_end']" position="before">
                <field name="date_start" />
            </xpath>
        </field>
    </record>
</odoo>
