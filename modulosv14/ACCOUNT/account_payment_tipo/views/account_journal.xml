<?xml version="1.0" encoding="utf-8" ?>
<odoo>

    <record id="view_account_journal_form" model="ir.ui.view">
        <field name="name">account_payment_tipo.account_journal.form</field>
        <field name="model">account.journal</field>
        <field name="inherit_id" ref="account.view_account_journal_form" />
        <field name="arch" type="xml">
            <xpath expr="//page[@name='advanced_settings']" position="after">
                <page name="tipo_settings" string="Tipo Settings">
                    <group>
                        <group string="Control-Access" groups="account.group_account_manager">
                            <field name="payment_tipo_ids" widget="many2many_tags"/>
                        </group>

                    </group>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
