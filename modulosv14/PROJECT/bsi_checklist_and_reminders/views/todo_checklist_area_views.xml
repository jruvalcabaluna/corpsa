<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <record id="view_todo_checklist_area_tree" model="ir.ui.view">
        <field name="name">todo.checklist.area.tree</field>
        <field name="model">todo.checklist.area</field>
        <field name="type">tree</field>
        <field name="arch" type="xml">
            <tree string="Checklist Area">
                <field name="name"/>
            </tree>
        </field>
    </record>

    <record id="view_todo_checklist_area_from" model="ir.ui.view">
        <field name="name">todo.checklist.area.form</field>
        <field name="model">todo.checklist.area</field>
        <field name="type">form</field>
        <field name="arch" type="xml">
            <form string="Checklist Area">
                <sheet>
                    <field name="name" required="1"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_todo_checklist_area" model="ir.actions.act_window">
        <field name="name">Checklist Area</field>
        <field name="type">ir.actions.act_window</field>
        <field name="res_model">todo.checklist.area</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[]</field>
        <field name="view_id" ref="view_todo_checklist_area_tree"/>
    </record>

    <menuitem id="menu_todo_checklist_area" name="Checklist Area" parent="project.menu_project_config"
        action="action_todo_checklist_area" sequence="20"/>
</odoo>
